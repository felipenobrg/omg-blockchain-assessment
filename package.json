{
  "name": "blockchain-hometask",
  "version": "1.0.0",
  "description": "Blockchain HomeTask Project with integrated frontend and backend",
  "main": "server.js",
  "scripts": {
    "start": "react-scripts start",
    "server": "node server.js",
    "dev": "nodemon server.js",
    "build": "react-scripts build",
    "serve": "npm run build && npm run server",
    "prod": "npm run serve",
    "lint": "eslint src --ext .js,.jsx",
    "test": "node --test tests/*.test.js",
    "test:contracts": "hardhat test",
    "test:frontend": "react-scripts test --watchAll=false"
  },
  "keywords": [
    "blockchain",
    "crypto",
    "react",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^17.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^8.2.1",
    "helmet": "^8.2.0",
    "http-proxy-middleware": "^2.0.6",
    "morgan": "^1.10.1",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1",
    "request": "^2.88.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "hardhat": "^2.28.6",
    "nodemon": "^3.0.1",
    "supertest": "^7.2.2"
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
