# Copy this file to .env and adjust values as needed.
# All variables have sane defaults in config/index.js, so .env is optional
# unless you need to change a port or disable demo data seeding.

# Node environment: development | production
NODE_ENV=development

# API server port
PORT=3002

# Origin allowed by CORS for the API (the React dev server)
CORS_ORIGIN=http://localhost:3000

# Mining difficulty (number of leading zeros required in the block hash)
BLOCKCHAIN_DIFFICULTY=2

# Reward granted to the miner address for each mined block
BLOCKCHAIN_MINING_REWARD=100

# Address credited when seeding demo data on first boot
INITIAL_MINER_ADDRESS=genesis-miner

# Set to "false" to skip seeding demo transactions/blocks on first boot
SEED_DEMO_DATA=true

# Where the blockchain state is persisted (defaults to ./blockchain.json)
BLOCKCHAIN_STATE_PATH=

# Base URL the React app proxies /api requests to (dev only)
REACT_APP_API_URL=http://localhost:3002
